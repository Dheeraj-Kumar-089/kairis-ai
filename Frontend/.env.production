# Loaded automatically by Vite when running `npm run build` (mode=production).
# This app is deployed as ONE Vercel project: Frontend/dist is copied into
# Backend/public and served by the same Express app, so frontend and backend
# share one origin. Empty value -> axios/socket.io fall back to same-origin
# relative requests, no code change needed between environments.
VITE_API_BASE_URL=
